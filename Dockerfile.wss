FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    openssl \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-wss.txt .
RUN pip install --no-cache-dir -r requirements-wss.txt

COPY servidor_wss_tunnel.py .

RUN mkdir -p /app/certs /app/logs

EXPOSE 8765

CMD ["python", "servidor_wss_tunnel.py"]
