FROM python:3.11-slim

WORKDIR /app

RUN apt-get update && apt-get install -y \
    curl \
    wget \
    && rm -rf /var/lib/apt/lists/*

COPY requirements-manager.txt .
RUN pip install --no-cache-dir -r requirements-manager.txt

COPY tunnel_manager.py .
COPY pyodide_tunnel_script.js /app/scripts/

RUN mkdir -p /app/logs /app/scripts

CMD ["python", "tunnel_manager.py"]
